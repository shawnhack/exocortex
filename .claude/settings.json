{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-commit.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash(git push)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-push.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
