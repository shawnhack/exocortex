{
  "name": "exocortex",
  "version": "0.5.0",
  "private": true,
  "description": "Personal unified memory system — SQLite-backed, local-first, hybrid RAG retrieval.",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "tsx watch packages/cli/src/index.ts serve",
    "test": "vitest run",
    "test:retrieval-gate": "tsx scripts/retrieval-regression-gate.mjs",
    "test:ui": "node scripts/test-memory-detail-layout.mjs && node scripts/test-dashboard-interactions.mjs",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "benchmark": "tsx scripts/run-benchmark.mts",
    "release": "bash scripts/release.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "ajv": ">=8.18.0",
      "qs": ">=6.14.2",
      "express-rate-limit": ">=8.2.2",
      "hono": ">=4.12.12",
      "path-to-regexp": ">=8.4.0",
      "lodash-es": ">=4.18.0",
      "picomatch": ">=4.0.4"
    }
  }
}
